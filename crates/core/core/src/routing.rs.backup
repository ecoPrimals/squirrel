use chrono::{DateTime, Utc};
use dashmap::DashMap;
use parking_lot::RwLock;
use std::collections::HashMap;
use std::sync::Arc;
use tokio::sync::{mpsc, Semaphore};
use tracing::{debug, error, info, warn}; // Added warn to imports

use crate::{
    AgentSpec, ContextRequirements, CoordinationResult, Error, McpRouter, McpTask, PrimalEndpoint,
    PrimalType, QueuedTask, ResponseMetadata, Result, RoutingStats, ScaleRequirements, ScaleResult,
    TaskPriority, TaskResponse,
};

/// Multi-MCP task routing and coordination service
///
/// This is the core of Squirrel MCP's functionality as a multi-MCP coordinator.
/// It handles:
/// - Routing MCP tasks to appropriate agents/primals
/// - Load balancing across multiple MCP endpoints
/// - Context coordination and persistence
/// - Performance optimization and scaling
/// - Federation across multiple nodes
#[derive(Clone)]
pub struct McpRoutingService {
    config: RoutingConfig,
    state: Arc<RoutingState>,
    agent_registry: Arc<DashMap<String, RegisteredAgent>>,
    task_queue: Arc<DashMap<String, QueuedTask>>,
    load_balancer: Arc<LoadBalancer>,
    context_manager: Arc<ContextManager>,
    http_client: reqwest::Client,
}

#[derive(Debug, Clone, serde::Serialize, serde::Deserialize)]
pub struct RoutingConfig {
    pub max_concurrent_tasks: usize,
    pub task_timeout: chrono::Duration,
    pub load_balancing_strategy: LoadBalancingStrategy,
    pub context_persistence: bool,
    pub federation_enabled: bool,
    pub scaling_enabled: bool,
    pub performance_monitoring: bool,

    // Manual selection and override configurations
    pub agent_selection_config: AgentSelectionConfig,
    pub agent_groups: HashMap<String, AgentGroup>,
    pub priority_overrides: HashMap<String, TaskPriority>,
    pub manual_routing_rules: Vec<ManualRoutingRule>,

    // Primal endpoints (fixed mappings)
    pub nestgate_endpoint: Option<String>, // Storage persistence
    pub toadstool_endpoint: Option<String>, // Compute
    pub beardog_endpoint: Option<String>,  // Security
    pub biomeos_endpoint: Option<String>,  // Integration
}

#[derive(Debug, Clone, serde::Serialize, serde::Deserialize)]
pub enum LoadBalancingStrategy {
    RoundRobin,
    LeastConnections,
    WeightedRoundRobin,
    ResponseTimeBased,
    CapabilityBased,
    Adaptive,
}

#[derive(Debug, Clone, serde::Serialize, serde::Deserialize)]
pub struct AgentSelectionConfig {
    pub allow_manual_override: bool,
    pub default_selection_mode: SelectionMode,
    pub fallback_enabled: bool,
    pub sticky_sessions: bool,
    pub prefer_local_agents: bool,
}

#[derive(Debug, Clone, serde::Serialize, serde::Deserialize)]
pub enum SelectionMode {
    Automatic,
    Manual,
    Hybrid,
}

#[derive(Debug, Clone, serde::Serialize, serde::Deserialize)]
pub struct AgentGroup {
    pub name: String,
    pub agents: Vec<String>,
    pub priority: u32,
    pub selection_strategy: LoadBalancingStrategy,
    pub max_concurrent_tasks: Option<usize>,
    pub failover_groups: Vec<String>,
    pub required_capabilities: Vec<String>,
    pub tags: HashMap<String, String>,
}

#[derive(Debug, Clone, serde::Serialize, serde::Deserialize)]
pub struct ManualRoutingRule {
    pub rule_id: String,
    pub condition: RoutingCondition,
    pub action: RoutingAction,
    pub priority: u32,
    pub enabled: bool,
}

#[derive(Debug, Clone, serde::Serialize, serde::Deserialize)]
pub enum RoutingCondition {
    TaskType(String),
    RequiredCapability(String),
    PrimalType(PrimalType),
    UserRequest(String),
    TaskTag(String, String),
    And(Vec<RoutingCondition>),
    Or(Vec<RoutingCondition>),
}

#[derive(Debug, Clone, serde::Serialize, serde::Deserialize)]
pub enum RoutingAction {
    UseAgent(String),
    UseAgentGroup(String),
    UsePrimal(PrimalType),
    SetPriority(TaskPriority),
    Reject(String),
}

// PrimalType is now imported from crate root (lib.rs) to avoid duplication

#[derive(Debug)]
struct RoutingState {
    node_id: String,
    active_tasks: RwLock<u64>,
    completed_tasks: RwLock<u64>,
    failed_tasks: RwLock<u64>,
    average_response_time: RwLock<f64>,
    last_scale_event: RwLock<Option<DateTime<Utc>>>,
    federation_nodes: RwLock<Vec<String>>,
}

#[derive(Debug, Clone)]
pub struct RegisteredAgent {
    pub id: String,
    pub endpoint: String,
    pub capabilities: Vec<String>,
    pub max_concurrent_tasks: u32,
    pub current_load: Arc<RwLock<u32>>,
    pub average_response_time: Arc<RwLock<f64>>,
    pub health_status: Arc<RwLock<AgentHealthStatus>>,
    pub last_seen: Arc<RwLock<DateTime<Utc>>>,
    pub metadata: HashMap<String, String>,
}

#[derive(Debug, Clone)]
pub enum AgentHealthStatus {
    Healthy,
    Degraded,
    Unhealthy,
    Offline,
}

#[derive(Debug)]
struct LoadBalancer {
    strategy: LoadBalancingStrategy,
    weights: RwLock<HashMap<String, f64>>,
    performance_history: RwLock<HashMap<String, Vec<PerformanceMetric>>>,
    semaphore: Arc<Semaphore>, // Add semaphore for concurrency control
}

#[derive(Debug, Clone)]
struct PerformanceMetric {
    timestamp: DateTime<Utc>,
    response_time: chrono::Duration,
    success: bool,
    load: u32,
}

#[derive(Debug)]
struct ContextManager {
    persistent_contexts: DashMap<String, PersistentContext>,
    shared_contexts: DashMap<String, SharedContext>,
    context_storage: Option<ContextStorage>,
}

#[derive(Debug, Clone)]
struct PersistentContext {
    context_id: String,
    agent_id: String,
    data: serde_json::Value,
    created_at: DateTime<Utc>,
    last_accessed: DateTime<Utc>,
    expiry: Option<DateTime<Utc>>,
}

#[derive(Debug, Clone)]
struct SharedContext {
    context_id: String,
    shared_with: Vec<String>,
    data: serde_json::Value,
    version: u64,
    last_modified: DateTime<Utc>,
}

#[derive(Debug)]
enum ContextStorage {
    Local,
    NestGate { endpoint: String },
    Federation { nodes: Vec<String> },
}

impl McpRoutingService {
    /// Create a new MCP routing service
    pub fn new(config: RoutingConfig) -> Result<Self> {
        let node_id = std::env::var("NODE_ID")
            .unwrap_or_else(|_| format!("squirrel-{}", uuid::Uuid::new_v4()));

        let state = Arc::new(RoutingState {
            node_id: node_id.clone(),
            active_tasks: RwLock::new(0),
            completed_tasks: RwLock::new(0),
            failed_tasks: RwLock::new(0),
            average_response_time: RwLock::new(0.0),
            last_scale_event: RwLock::new(None),
            federation_nodes: RwLock::new(Vec::new()),
        });

        let load_balancer = Arc::new(LoadBalancer {
            strategy: config.load_balancing_strategy.clone(),
            weights: RwLock::new(HashMap::new()),
            performance_history: RwLock::new(HashMap::new()),
            semaphore: Arc::new(Semaphore::new(config.max_concurrent_tasks)),
        });

        let context_manager = Arc::new(ContextManager {
            persistent_contexts: DashMap::new(),
            shared_contexts: DashMap::new(),
            context_storage: if config.context_persistence {
                Some(ContextStorage::Local) // Will be enhanced with NestGate integration
            } else {
                None
            },
        });

        let http_client = reqwest::Client::builder()
            .timeout(
                config
                    .task_timeout
                    .to_std()
                    .unwrap_or(std::time::Duration::from_secs(60)),
            )
            .build()?;

        Ok(Self {
            config,
            state,
            agent_registry: Arc::new(DashMap::new()),
            task_queue: Arc::new(DashMap::new()),
            load_balancer,
            context_manager,
            http_client,
        })
    }

    /// Start the routing service
    pub async fn start(&self) -> Result<()> {
        tracing::info!("Starting MCP routing service");

        // Start background tasks
        self.start_background_tasks().await;

        tracing::info!("MCP routing service started successfully");
        Ok(())
    }

    /// Start background processing tasks
    async fn start_background_tasks(&self) {
        // Task processing worker
        let service = self.clone();
        tokio::spawn(async move {
            service.task_processing_loop().await;
        });

        // Health monitoring
        let service = self.clone();
        tokio::spawn(async move {
            service.health_monitoring_loop().await;
        });

        // Performance monitoring
        if self.config.performance_monitoring {
            let service = self.clone();
            tokio::spawn(async move {
                service.performance_monitoring_loop().await;
            });
        }

        // Auto-scaling
        if self.config.scaling_enabled {
            let service = self.clone();
            tokio::spawn(async move {
                service.auto_scaling_loop().await;
            });
        }
    }

    /// Main task processing loop
    async fn task_processing_loop(&self) {
        let routing_service = self.clone();
        let semaphore = Arc::clone(&self.load_balancer.semaphore);

        loop {
            // Find next task to process
            if let Some((task_id, queued_task)) = self.find_next_task() {
                let routing_service = routing_service.clone();
                let sem = Arc::clone(&semaphore);

                tokio::spawn(async move {
                    // Try to acquire a permit for concurrency control
                    if let Ok(permit) = sem.acquire().await {
                        let _permit = permit; // Hold permit for task duration
                        if let Err(e) = routing_service
                            .process_task(task_id.clone(), queued_task.clone())
                            .await
                        {
                            routing_service
                                .handle_task_failure(&task_id, &queued_task, e)
                                .await;
                        }
                    }
                });
            } else {
                // No tasks available, sleep briefly
                tokio::time::sleep(tokio::time::Duration::from_millis(100)).await;
            }
        }
    }

    /// Find the next task to process based on priority and scheduling
    fn find_next_task(&self) -> Option<(String, QueuedTask)> {
        let mut best_task: Option<(String, QueuedTask)> = None;
        let mut best_priority = TaskPriority::Background;

        for entry in self.task_queue.iter() {
            let (task_id, queued_task) = entry.pair();

            // Check if task is ready to be processed
            if true {
                if queued_task.priority <= best_priority {
                    best_priority = queued_task.priority.clone();
                    best_task = Some((task_id.clone(), queued_task.clone()));
                }
            }
        }

        if let Some((task_id, _)) = &best_task {
            self.task_queue.remove(task_id);
        }

        best_task
    }

    /// Process a single task
    async fn process_task(&self, task_id: String, mut queued_task: QueuedTask) -> Result<()> {
        let start_time = Utc::now();
        *self.state.active_tasks.write() += 1;

        tracing::debug!("Processing task: {}", task_id);

        // Select best agent for this task
        let selected_agent = match self.select_agent_for_task(&queued_task.task).await {
            Ok(agent) => agent,
            Err(e) => {
                tracing::error!("Failed to select agent for task {}: {}", task_id, e);
                self.handle_task_failure(&task_id, &queued_task, e).await;
                return Ok(());
            }
        };

        // Note: assigned_agent field doesn't exist on QueuedTask,
        // tracking would need to be handled differently if needed

        // Execute the task
        let result = self
            .execute_task_on_agent(&queued_task.task, &selected_agent)
            .await;

        // Update metrics
        let execution_time = Utc::now() - start_time;
        self.update_performance_metrics(&selected_agent.id, &execution_time, result.is_ok())
            .await;

        match result {
            Ok(response) => {
                tracing::debug!("Task {} completed successfully", task_id);
                *self.state.completed_tasks.write() += 1;

                // Handle context updates if needed
                if let Some(ref context_reqs) = queued_task.task.context_requirements {
                    self.handle_context_updates(&queued_task.task, &response, context_reqs)
                        .await?;
                }
            }
            Err(e) => {
                tracing::error!("Task {} failed: {}", task_id, e);
                self.handle_task_failure(&task_id, &queued_task, e).await;
            }
        }

        *self.state.active_tasks.write() -= 1;
        Ok(())
    }

    /// Select the best agent for a given task
    /// Now supports manual selection, agent groups, and primal routing
    async fn select_agent_for_task(&self, task: &McpTask) -> Result<RegisteredAgent> {
        // 1. Check manual routing rules first
        if let Some(override_action) = self.check_manual_routing_rules(task).await? {
            match override_action {
                RoutingAction::UseAgent(agent_id) => {
                    if let Some(agent) = self.agent_registry.get(&agent_id) {
                        return Ok(agent.clone());
                    }
                }
                RoutingAction::UseAgentGroup(group_name) => {
                    if let Some(group) = self.config.agent_groups.get(&group_name) {
                        return self.select_agent_from_group(group, task).await;
                    }
                }
                RoutingAction::UsePrimal(primal_type) => {
                    return self.route_to_primal(primal_type, task).await;
                }
                RoutingAction::SetPriority(_) => {
                    // Priority override handled elsewhere
                }
                RoutingAction::Reject(reason) => {
                    return Err(Error::Routing(format!("Task rejected: {}", reason)));
                }
            }
        }

        // 2. Check if manual override is requested in task
        if self.config.agent_selection_config.allow_manual_override {
            // Check routing hints for preferred agent/group
            if let Some(preferred_agent) = self.extract_hint(&task.routing_hints, "preferred_agent")
            {
                if let Some(agent) = self.agent_registry.get(&preferred_agent) {
                    return Ok(agent.clone());
                }
            }
            if let Some(preferred_group) = self.extract_hint(&task.routing_hints, "preferred_group")
            {
                if let Some(group) = self.config.agent_groups.get(&preferred_group) {
                    return self.select_agent_from_group(group, task).await;
                }
            }
        }

        // 3. Check primal routing requirements
        if let Some(primal_requirement) = self.determine_primal_requirement(task) {
            return self.route_to_primal(primal_requirement, task).await;
        }

        // 4. Use automatic selection based on configuration
        match self.config.agent_selection_config.default_selection_mode {
            SelectionMode::Manual => {
                return Err(Error::Routing(
                    "Manual selection required but no agent specified".to_string(),
                ));
            }
            SelectionMode::Automatic | SelectionMode::Hybrid => {
                // Continue with automatic selection
            }
        }

        // 5. Find suitable agents and select the best one
        let suitable_agents = self.find_suitable_agents(task).await?;
        if suitable_agents.is_empty() {
            return Err(Error::Routing("No suitable agents available".to_string()));
        }

        self.load_balancer.select_agent(suitable_agents).await
    }

    /// Check manual routing rules for a task
    async fn check_manual_routing_rules(&self, task: &McpTask) -> Result<Option<RoutingAction>> {
        let mut applicable_rules: Vec<&ManualRoutingRule> = self
            .config
            .manual_routing_rules
            .iter()
            .filter(|rule| rule.enabled && self.evaluate_routing_condition(&rule.condition, task))
            .collect();

        // Sort by priority (higher priority first)
        applicable_rules.sort_by(|a, b| b.priority.cmp(&a.priority));

        Ok(applicable_rules.first().map(|rule| rule.action.clone()))
    }

    /// Evaluate routing condition for a task
    fn evaluate_routing_condition(&self, condition: &RoutingCondition, task: &McpTask) -> bool {
        match condition {
            RoutingCondition::TaskType(task_type) => {
                // Use routing hints or context to determine task type
                self.get_context_value(task, "task_type")
                    .map_or(false, |t| t == *task_type)
            }
            RoutingCondition::RequiredCapability(capability) => {
                // Check routing hints for capability requirements
                task.routing_hints
                    .iter()
                    .any(|hint| hint.contains(capability))
            }
            RoutingCondition::PrimalType(primal_type) => {
                self.determine_primal_requirement(task) == Some(primal_type.clone())
            }
            RoutingCondition::UserRequest(user_id) => self
                .get_context_value(task, "user_id")
                .map_or(false, |u| u == *user_id),
            RoutingCondition::TaskTag(key, value) => self
                .get_context_value(task, key)
                .map_or(false, |v| v == *value),
            RoutingCondition::And(conditions) => conditions
                .iter()
                .all(|c| self.evaluate_routing_condition(c, task)),
            RoutingCondition::Or(conditions) => conditions
                .iter()
                .any(|c| self.evaluate_routing_condition(c, task)),
        }
    }

    /// Determine if a task requires routing to a specific primal
    fn determine_primal_requirement(&self, task: &McpTask) -> Option<PrimalType> {
        // Check explicit primal request
        if let Some(primal_str) = self.get_context_value(task, "target_primal") {
            match primal_str.as_str() {
                "nestgate" => return Some(PrimalType::NestGate),
                "toadstool" => return Some(PrimalType::ToadStool),
                "beardog" => return Some(PrimalType::BearDog),
                "biomeos" => return Some(PrimalType::BiomeOS),
                _ => {}
            }
        }

        // Infer primal based on task requirements
        if let Some(context_reqs) = &task.context_requirements {
            // Storage persistence tasks -> NestGate
            if context_reqs.persistent_context
                || context_reqs.context_keys.contains(&"storage".to_string())
                || context_reqs
                    .context_keys
                    .contains(&"persistence".to_string())
            {
                return Some(PrimalType::NestGate);
            }

            // Compute-intensive tasks -> ToadStool
            if context_reqs.context_keys.contains(&"compute".to_string())
                || context_reqs
                    .context_keys
                    .contains(&"processing".to_string())
                || context_reqs
                    .context_keys
                    .contains(&"calculation".to_string())
            {
                return Some(PrimalType::ToadStool);
            }

            // Security tasks -> BearDog
            if context_reqs.context_keys.contains(&"security".to_string())
                || context_reqs.context_keys.contains(&"auth".to_string())
                || context_reqs
                    .context_keys
                    .contains(&"encryption".to_string())
            {
                return Some(PrimalType::BearDog);
            }
        }

        // Default: stay local
        None
    }

    /// Route a task to a specific primal
    async fn route_to_primal(
        &self,
        primal_type: PrimalType,
        task: &McpTask,
    ) -> Result<RegisteredAgent> {
        let endpoint = match primal_type {
            PrimalType::NestGate => self.config.nestgate_endpoint.as_ref(),
            PrimalType::ToadStool => self.config.toadstool_endpoint.as_ref(),
            PrimalType::BearDog => self.config.beardog_endpoint.as_ref(),
            PrimalType::BiomeOS => self.config.biomeos_endpoint.as_ref(),
            PrimalType::Squirrel => None,
            PrimalType::Songbird => None, // Stay local
        };

        match endpoint {
            Some(endpoint_url) => {
                // Create a virtual agent for the primal
                Ok(RegisteredAgent {
                    id: format!("{:?}-primal", primal_type),
                    endpoint: endpoint_url.clone(),
                    capabilities: self.get_primal_capabilities(primal_type),
                    max_concurrent_tasks: 50,
                    current_load: Arc::new(RwLock::new(0)),
                    average_response_time: Arc::new(RwLock::new(100.0)),
                    health_status: Arc::new(RwLock::new(AgentHealthStatus::Healthy)),
                    last_seen: Arc::new(RwLock::new(chrono::Utc::now())),
                    metadata: HashMap::new(),
                })
            }
            None => {
                // Fallback to local agents
                let suitable_agents = self.find_suitable_agents(task).await?;
                if suitable_agents.is_empty() {
                    return Err(Error::Routing(format!(
                        "No {} primal endpoint configured and no suitable local agents",
                        primal_type
                    )));
                }
                self.load_balancer.select_agent(suitable_agents).await
            }
        }
    }

    /// Get capabilities for a primal type
    fn get_primal_capabilities(&self, primal_type: PrimalType) -> Vec<String> {
        match primal_type {
            PrimalType::NestGate => vec![
                "storage".to_string(),
                "persistence".to_string(),
                "database".to_string(),
                "file-system".to_string(),
            ],
            PrimalType::ToadStool => vec![
                "compute".to_string(),
                "processing".to_string(),
                "calculation".to_string(),
                "analysis".to_string(),
            ],
            PrimalType::BearDog => vec![
                "security".to_string(),
                "auth".to_string(),
                "encryption".to_string(),
                "access-control".to_string(),
            ],
            PrimalType::BiomeOS => vec![
                "integration".to_string(),
                "coordination".to_string(),
                "workflow".to_string(),
                "orchestration".to_string(),
            ],
            PrimalType::Squirrel => vec![
                "mcp".to_string(),
                "routing".to_string(),
                "coordination".to_string(),
                "load-balancing".to_string(),
            ],
            PrimalType::Songbird => vec![
                "load-balancing".to_string(),
                "scaling".to_string(),
                "federation".to_string(),
                "coordination".to_string(),
            ],
        }
    }

    /// Select an agent from a specific group
    async fn select_agent_from_group(
        &self,
        group: &AgentGroup,
        task: &McpTask,
    ) -> Result<RegisteredAgent> {
        let group_agents: Vec<RegisteredAgent> = group
            .agents
            .iter()
            .filter_map(|agent_id| self.agent_registry.get(agent_id))
            .map(|agent| agent.clone())
            .collect();

        if group_agents.is_empty() {
            // Try failover groups
            for failover_group_name in &group.failover_groups {
                if let Some(failover_group) = self.config.agent_groups.get(failover_group_name) {
                    if let Ok(agent) =
                        Box::pin(self.select_agent_from_group(failover_group, task)).await
                    {
                        return Ok(agent);
                    }
                }
            }
            return Err(Error::Routing(format!(
                "No agents available in group: {}",
                group.name
            )));
        }

        // Use group-specific selection strategy
        let group_balancer = LoadBalancer {
            strategy: group.selection_strategy.clone(),
            weights: RwLock::new(HashMap::new()),
            performance_history: RwLock::new(HashMap::new()),
            semaphore: Arc::new(Semaphore::new(1)), // Each group has its own semaphore
        };

        group_balancer.select_agent(group_agents).await
    }

    /// Find agents suitable for a task based on capabilities and requirements
    async fn find_suitable_agents(&self, task: &McpTask) -> Result<Vec<RegisteredAgent>> {
        let mut suitable = Vec::new();

        for entry in self.agent_registry.iter() {
            let agent = entry.value();

            // Check health
            if !matches!(*agent.health_status.read(), AgentHealthStatus::Healthy) {
                continue;
            }

            // Check load
            if *agent.current_load.read() >= agent.max_concurrent_tasks {
                continue;
            }

            // Check capabilities if routing hints are provided
            if !task.routing_hints.is_empty() {
                let hints = &task.routing_hints;
                if !vec!["placeholder"].is_empty() {
                    let has_required_caps = vec!["placeholder"]
                        .iter()
                        .all(|cap| agent.capabilities.contains(&cap.to_string()));

                    if !has_required_caps {
                        continue;
                    }
                }

                // Check preferred agents
                if !vec!["placeholder"].is_empty() {
                    if !false {
                        continue;
                    }
                }
            }

            suitable.push(agent.clone());
        }

        Ok(suitable)
    }

    /// Execute a task on a specific agent
    async fn execute_task_on_agent(
        &self,
        task: &McpTask,
        agent: &RegisteredAgent,
    ) -> Result<TaskResponse> {
        // Increment agent load
        *agent.current_load.write() += 1;

        let start_time = Utc::now();

        // Build MCP request
        let mcp_request = self.build_mcp_request(task, agent).await?;

        // Send request to agent
        let response = self
            .http_client
            .post(&format!("{}/mcp", agent.endpoint))
            .json(&mcp_request)
            .send()
            .await?;

        // Decrement agent load
        *agent.current_load.write() -= 1;

        if !response.status().is_success() {
            return Err(Error::Routing(format!(
                "Agent returned error: {}",
                response.status()
            )));
        }

        let mcp_response: serde_json::Value = response.json().await?;
        let execution_time = Utc::now() - start_time;

        let agent_id = if let Some(ref agent_id) = task.agent_id {
            agent_id.clone()
        } else {
            return Err(Error::Routing("Agent ID is required".to_string()));
        };

        let mut request = task.mcp_request.clone();

        // Add context if required
        if let Some(ref context_reqs) = task.context_requirements {
            // Handle context requirements
            if context_reqs.persistent_context || context_reqs.shared_context {
                if let Some(context_data) = self.context_manager.get_context(&agent_id).await {
                    request["context"] = context_data;
                }
            }
        }

        // Add routing metadata
        request["routing_metadata"] = serde_json::json!({
            "squirrel_node": self.state.node_id,
            "agent_id": agent.id,
            "task_id": task.id,
            "timestamp": Utc::now().to_rfc3339()
        });

        Ok(TaskResponse {
            task_id: task.id.clone(),
            id: task.id.clone(),
            response: mcp_response.clone(),
            result: mcp_response,
            metadata: ResponseMetadata {
                context_updated: task.context_requirements.is_some(),
                processing_time: execution_time.to_std().unwrap_or_default(),
                agent_version: None,
            },
            agent_id: agent.id.clone(),
            execution_time: execution_time.to_std().unwrap_or_default(),
            context: task.context.clone(),
        })
    }

    /// Build MCP request for an agent
    async fn build_mcp_request(
        &self,
        task: &McpTask,
        agent: &RegisteredAgent,
    ) -> Result<serde_json::Value> {
        let mut request = task.mcp_request.clone();

        // Add context if required
        if let Some(ref context_reqs) = task.context_requirements {
            if context_reqs.persistent_context || context_reqs.shared_context {
                if let Some(context_data) = self.context_manager.get_context(&agent.id).await {
                    request["context"] = context_data;
                }
            }
        }

        // Add routing metadata
        request["routing_metadata"] = serde_json::json!({
            "squirrel_node": self.state.node_id,
            "agent_id": agent.id,
            "task_id": task.id,
            "timestamp": Utc::now().to_rfc3339()
        });

        Ok(request)
    }

    /// Handle context updates after task execution
    async fn handle_context_updates(
        &self,
        task: &McpTask,
        response: &TaskResponse,
        context_reqs: &ContextRequirements,
    ) -> Result<()> {
        if context_reqs.persistent_context {
            if let Some(context_data) = response.result.get("context") {
                if let Some(agent_id) = task.agent_id.as_ref() {
                    self.context_manager
                        .update_persistent_context(agent_id, context_data.clone())
                        .await?;
                } else {
                    warn!("Cannot update persistent context: task has no agent_id");
                }
            }
        }

        if context_reqs.shared_context {
            if let Some(context_data) = response.result.get("shared_context") {
                // Update shared context for all agents
                // Implementation depends on federation setup
            }
        }

        Ok(())
    }

    /// Handle task failure with retry logic
    async fn handle_task_failure(&self, task_id: &str, queued_task: &QueuedTask, error: Error) {
        *self.state.failed_tasks.write() += 1;

        // Implement retry logic
        if queued_task.retry_count < queued_task.max_retries {
            let mut retry_task = queued_task.clone();
            retry_task.retry_count += 1;
            // Note: assigned_agent field doesn't exist on QueuedTask

            // Exponential backoff
            let delay = std::time::Duration::from_secs(2_u64.pow(retry_task.retry_count));

            let task_queue = self.task_queue.clone();
            let task_id = task_id.to_string();
            let task_id_for_log = task_id.clone();

            tokio::spawn(async move {
                tokio::time::sleep(delay).await;
                task_queue.insert(task_id, retry_task);
            });

            tracing::warn!(
                "Task {} failed, scheduling retry (attempt {}): {}",
                task_id_for_log,
                queued_task.retry_count + 1,
                error
            );
        } else {
            tracing::error!(
                "Task {} failed permanently after {} attempts: {}",
                task_id,
                queued_task.retry_count,
                error
            );
        }
    }

    /// Update performance metrics for an agent
    async fn update_performance_metrics(
        &self,
        agent_id: &str,
        execution_time: &chrono::Duration,
        success: bool,
    ) {
        if let Some(agent) = self.agent_registry.get(agent_id) {
            // Update agent's average response time
            let mut avg_time = agent.average_response_time.write();
            let new_time = execution_time.num_milliseconds() as f64;
            *avg_time = (*avg_time * 0.9) + (new_time * 0.1); // Exponential moving average
        }

        // Update global metrics
        {
            let mut global_avg = self.state.average_response_time.write();
            let new_time = execution_time.num_milliseconds() as f64;
            *global_avg = (*global_avg * 0.95) + (new_time * 0.05);
        }

        // Add to performance history
        let metric = PerformanceMetric {
            timestamp: Utc::now(),
            response_time: execution_time.clone(),
            success,
            load: self
                .agent_registry
                .get(agent_id)
                .map(|a| *a.current_load.read())
                .unwrap_or(0),
        };

        let mut history = self.load_balancer.performance_history.write();
        history
            .entry(agent_id.to_string())
            .or_insert_with(Vec::new)
            .push(metric);

        // Keep only last 100 metrics per agent
        if let Some(agent_history) = history.get_mut(agent_id) {
            if agent_history.len() > 100 {
                agent_history.remove(0);
            }
        }
    }

    /// Health monitoring loop
    async fn health_monitoring_loop(&self) {
        let mut interval = tokio::time::interval(std::time::Duration::from_secs(30));

        loop {
            interval.tick().await;

            for entry in self.agent_registry.iter() {
                let agent = entry.value();
                let health_url = format!("{}/health", agent.endpoint);

                match self.http_client.get(&health_url).send().await {
                    Ok(response) => {
                        let new_status = match response.status().as_u16() {
                            200 => AgentHealthStatus::Healthy,
                            500..=599 => AgentHealthStatus::Degraded,
                            _ => AgentHealthStatus::Unhealthy,
                        };
                        *agent.health_status.write() = new_status;
                        *agent.last_seen.write() = Utc::now();
                    }
                    Err(_) => {
                        *agent.health_status.write() = AgentHealthStatus::Offline;
                    }
                }
            }
        }
    }

    /// Performance monitoring loop
    async fn performance_monitoring_loop(&self) {
        let mut interval = tokio::time::interval(std::time::Duration::from_secs(60));

        loop {
            interval.tick().await;

            let active_tasks = *self.state.active_tasks.read();
            let completed_tasks = *self.state.completed_tasks.read();
            let failed_tasks = *self.state.failed_tasks.read();
            let avg_response_time = *self.state.average_response_time.read();

            tracing::info!(
                "MCP Routing Metrics - Active: {}, Completed: {}, Failed: {}, Avg Response: {:.2}ms",
                active_tasks, completed_tasks, failed_tasks, avg_response_time
            );
        }
    }

    /// Auto-scaling loop
    async fn auto_scaling_loop(&self) {
        let mut interval = tokio::time::interval(std::time::Duration::from_secs(120));

        loop {
            interval.tick().await;

            // Check if scaling is needed
            let active_tasks = *self.state.active_tasks.read();
            let queue_length = self.task_queue.len();
            let avg_response_time = *self.state.average_response_time.read();

            // Simple scaling logic - would be more sophisticated in practice
            if queue_length > 10 || avg_response_time > 5000.0 {
                tracing::info!("High load detected, scaling may be needed");
                // In a real implementation, this would trigger scaling actions
            }
        }
    }

    /// Register a new MCP agent
    pub async fn register_agent(&self, agent_spec: AgentSpec) -> Result<()> {
        let agent = RegisteredAgent {
            id: agent_spec.id.clone(),
            endpoint: agent_spec.endpoint,
            capabilities: agent_spec.capabilities,
            max_concurrent_tasks: 10, // Default value since AgentSpec doesn't have this field
            current_load: Arc::new(RwLock::new(0)),
            average_response_time: Arc::new(RwLock::new(0.0)),
            health_status: Arc::new(RwLock::new(AgentHealthStatus::Healthy)),
            last_seen: Arc::new(RwLock::new(Utc::now())),
            metadata: agent_spec.metadata,
        };

        self.agent_registry.insert(agent_spec.id.clone(), agent);
        tracing::info!("Registered MCP agent: {}", agent_spec.id);

        Ok(())
    }

    /// Queue a new task for processing
    pub async fn queue_task(&self, task: McpTask, priority: TaskPriority) -> Result<String> {
        let task_id = task.id.clone();

        let queued_task = QueuedTask {
            task,
            priority,
            queued_at: Utc::now(),
            retry_count: 0,
            max_retries: 3,
        };

        self.task_queue.insert(task_id.clone(), queued_task);
        tracing::debug!("Queued task: {}", task_id);

        Ok(task_id)
    }

    /// Get routing statistics
    pub fn get_stats(&self) -> RoutingStats {
        RoutingStats {
            active_tasks: *self.state.active_tasks.read(),
            completed_tasks: *self.state.completed_tasks.read(),
            failed_tasks: *self.state.failed_tasks.read(),
            queued_tasks: self.task_queue.len() as u64,
            registered_agents: self.agent_registry.len() as u32,
            average_response_time: *self.state.average_response_time.read(),
            federation_nodes: self.state.federation_nodes.read().len() as u32,
        }
    }

    /// Helper method to extract information from routing hints
    fn extract_hint(&self, routing_hints: &[String], hint_type: &str) -> Option<String> {
        routing_hints
            .iter()
            .find(|hint| hint.starts_with(&format!("{}:", hint_type)))
            .and_then(|hint| hint.split(':').nth(1))
            .map(|s| s.to_string())
    }

    /// Helper method to get metadata-like information from context
    fn get_context_value(&self, task: &McpTask, key: &str) -> Option<String> {
        task.context
            .as_ref()
            .and_then(|ctx| ctx.get(key))
            .and_then(|v| v.as_str())
            .map(|s| s.to_string())
    }
}

#[async_trait::async_trait]
impl McpRouter for McpRoutingService {
    async fn route_task(&self, task: McpTask) -> Result<TaskResponse> {
        // For direct routing (non-queued), execute immediately
        let selected_agent = self.select_agent_for_task(&task).await?;
        self.execute_task_on_agent(&task, &selected_agent).await
    }

    async fn coordinate_agents(&self, agents: Vec<AgentSpec>) -> Result<CoordinationResult> {
        let mut registered = 0;
        let mut failed = 0;

        for agent_spec in agents {
            match self.register_agent(agent_spec).await {
                Ok(_) => registered += 1,
                Err(e) => {
                    tracing::error!("Failed to register agent: {}", e);
                    failed += 1;
                }
            }
        }

        Ok(CoordinationResult {
            registered_agents: registered,
            failed_registrations: failed,
            total_agents: self.agent_registry.len() as u32,
            status: if failed == 0 {
                "success".to_string()
            } else {
                "partial".to_string()
            },
        })
    }

    async fn scale_capacity(&self, requirements: ScaleRequirements) -> Result<ScaleResult> {
        // This would implement actual scaling logic
        // For now, return a mock result
        *self.state.last_scale_event.write() = Some(Utc::now());

        Ok(ScaleResult {
            scaling_triggered: true,
            target_instances: requirements.max_instances,
            current_instances: self.agent_registry.len() as u32,
            scaling_status: "in_progress".to_string(),
        })
    }
}

// Supporting types and implementations

impl LoadBalancer {
    async fn select_agent(&self, agents: Vec<RegisteredAgent>) -> Result<RegisteredAgent> {
        if agents.is_empty() {
            return Err(Error::Routing("No agents available".to_string()));
        }

        match self.strategy {
            LoadBalancingStrategy::RoundRobin => {
                // Simple round-robin (would need state tracking in real implementation)
                Ok(agents[0].clone())
            }
            LoadBalancingStrategy::LeastConnections => {
                let best_agent = agents
                    .iter()
                    .min_by_key(|agent| *agent.current_load.read())
                    .ok_or_else(|| {
                        Error::Routing(
                            "No agents available for least connections selection".to_string(),
                        )
                    })?;
                Ok(best_agent.clone())
            }
            LoadBalancingStrategy::ResponseTimeBased => {
                let best_agent = agents
                    .iter()
                    .min_by(|a, b| {
                        let a_time = a.average_response_time.read();
                        let b_time = b.average_response_time.read();
                        a_time
                            .partial_cmp(&b_time)
                            .unwrap_or(std::cmp::Ordering::Equal)
                    })
                    .ok_or_else(|| {
                        Error::Routing(
                            "No agents available for response time based selection".to_string(),
                        )
                    })?;
                Ok(best_agent.clone())
            }
            _ => {
                // Default to least connections
                let best_agent = agents
                    .iter()
                    .min_by_key(|agent| *agent.current_load.read())
                    .ok_or_else(|| {
                        Error::Routing("No agents available for default selection".to_string())
                    })?;
                Ok(best_agent.clone())
            }
        }
    }
}

impl ContextManager {
    async fn get_context(&self, agent_id: &str) -> Option<serde_json::Value> {
        self.persistent_contexts
            .get(agent_id)
            .map(|ctx| ctx.data.clone())
    }

    async fn update_persistent_context(
        &self,
        agent_id: &str,
        data: serde_json::Value,
    ) -> Result<()> {
        let context = PersistentContext {
            context_id: format!("ctx-{}", uuid::Uuid::new_v4()),
            agent_id: agent_id.to_string(),
            data,
            created_at: Utc::now(),
            last_accessed: Utc::now(),
            expiry: None,
        };

        self.persistent_contexts
            .insert(agent_id.to_string(), context);
        Ok(())
    }

    async fn update_shared_context(&self, context_id: &str, data: serde_json::Value) -> Result<()> {
        let context = SharedContext {
            context_id: context_id.to_string(),
            shared_with: vec![],
            data,
            version: 1,
            last_modified: Utc::now(),
        };

        self.shared_contexts.insert(context_id.to_string(), context);
        Ok(())
    }
}

// Additional types are defined in lib.rs to avoid duplication
// Removed duplicate definitions of: CoordinationResult, ScaleResult, RoutingStats

impl Default for RoutingConfig {
    fn default() -> Self {
        Self {
            max_concurrent_tasks: 100,
            task_timeout: chrono::Duration::seconds(60),
            load_balancing_strategy: LoadBalancingStrategy::LeastConnections,
            context_persistence: true,
            federation_enabled: true,
            scaling_enabled: true,
            performance_monitoring: true,

            // Manual selection and override configurations
            agent_selection_config: AgentSelectionConfig {
                allow_manual_override: true,
                default_selection_mode: SelectionMode::Hybrid,
                fallback_enabled: true,
                sticky_sessions: false,
                prefer_local_agents: false,
            },
            agent_groups: HashMap::new(),
            priority_overrides: HashMap::new(),
            manual_routing_rules: Vec::new(),

            // Primal endpoints (fixed mappings)
            nestgate_endpoint: None,
            toadstool_endpoint: None,
            beardog_endpoint: None,
            biomeos_endpoint: None,
        }
    }
}
