    pub progress: f64,
    
    /// Step started at
    pub started_at: Option<DateTime<Utc>>,
    
    /// Step completed at
    pub completed_at: Option<DateTime<Utc>>,
    
    /// Step result
    pub result: Option<serde_json::Value>,
    
    /// Step errors
    pub errors: Vec<String>,
    
    /// Step metrics
    pub metrics: StepMetrics,
}

/// Step status
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
pub enum StepStatus {
    /// Pending
    Pending,
    
    /// Executing
    Executing,
    
    /// Completed
    Completed,
    
    /// Failed
    Failed,
    
    /// Skipped
    Skipped,
    
    /// Cancelled
    Cancelled,
    
    /// Retrying
    Retrying,
}

