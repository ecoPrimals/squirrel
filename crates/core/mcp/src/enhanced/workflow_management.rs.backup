/// Memory-based workflow state persistence implementation
pub struct MemoryWorkflowStatePersistence {
    storage: Arc<RwLock<HashMap<String, WorkflowState>>>,
    checkpoints: Arc<RwLock<HashMap<String, Vec<StateCheckpoint>>>>,
}

impl MemoryWorkflowStatePersistence {
    pub fn new() -> Self {
        Self {
            storage: Arc::new(RwLock::new(HashMap::new())),
            checkpoints: Arc::new(RwLock::new(HashMap::new())),
        }
    }
}

#[async_trait::async_trait]
impl WorkflowStatePersistence for MemoryWorkflowStatePersistence {
    async fn save_state(&self, workflow_id: &str, state: &WorkflowState) -> Result<()> {
        let mut storage = self.storage.write().await;
        storage.insert(workflow_id.to_string(), state.clone());
        Ok(())
    }
    
    async fn load_state(&self, workflow_id: &str) -> Result<Option<WorkflowState>> {
        let storage = self.storage.read().await;
        Ok(storage.get(workflow_id).cloned())
    }
    
    async fn delete_state(&self, workflow_id: &str) -> Result<()> {
        let mut storage = self.storage.write().await;
        storage.remove(workflow_id);
        Ok(())
    }
    
    async fn list_states(&self) -> Result<Vec<String>> {
        let storage = self.storage.read().await;
        Ok(storage.keys().cloned().collect())
    }
    
    async fn save_checkpoint(&self, workflow_id: &str, checkpoint: &StateCheckpoint) -> Result<()> {
        let mut checkpoints = self.checkpoints.write().await;
        checkpoints.entry(workflow_id.to_string())
            .or_insert_with(Vec::new)
            .push(checkpoint.clone());
        Ok(())
    }
    
    async fn load_checkpoint(&self, workflow_id: &str, checkpoint_id: &str) -> Result<Option<StateCheckpoint>> {
        let checkpoints = self.checkpoints.read().await;
        if let Some(workflow_checkpoints) = checkpoints.get(workflow_id) {
            for checkpoint in workflow_checkpoints {
                if checkpoint.id == checkpoint_id {
                    return Ok(Some(checkpoint.clone()));
                }
            }
        }
        Ok(None)
    }
}

