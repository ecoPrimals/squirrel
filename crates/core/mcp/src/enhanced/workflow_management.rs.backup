/// Workflow state persistence trait
#[async_trait::async_trait]
pub trait WorkflowStatePersistence: Send + Sync {
    /// Save state
    async fn save_state(&self, workflow_id: &str, state: &WorkflowState) -> Result<()>;
    
    /// Load state
    async fn load_state(&self, workflow_id: &str) -> Result<Option<WorkflowState>>;
    
    /// Delete state
    async fn delete_state(&self, workflow_id: &str) -> Result<()>;
    
    /// List states
    async fn list_states(&self) -> Result<Vec<String>>;
    
    /// Save checkpoint
    async fn save_checkpoint(&self, workflow_id: &str, checkpoint: &StateCheckpoint) -> Result<()>;
    
    /// Load checkpoint
    async fn load_checkpoint(&self, workflow_id: &str, checkpoint_id: &str) -> Result<Option<StateCheckpoint>>;
}

