    /// Success rate
    pub success_rate: f64,
    
    /// Error rate
    pub error_rate: f64,
}

/// Workflow execution engine
#[derive(Debug)]
pub struct WorkflowExecutionEngine {
    /// Configuration
    config: WorkflowExecutionConfig,
    
    /// Execution pool
    execution_pool: Arc<tokio::task::JoinSet<WorkflowExecutionResult>>,
    
    /// Execution state
    execution_state: Arc<RwLock<HashMap<String, WorkflowExecutionState>>>,
    
    /// Step executors
    step_executors: Arc<RwLock<HashMap<WorkflowStepType, Arc<dyn StepExecutor>>>>,
    
    /// Condition evaluator
    condition_evaluator: Arc<ConditionEvaluator>,
    
    /// Expression engine
    expression_engine: Arc<ExpressionEngine>,
}

/// Step executor trait
#[async_trait::async_trait]
pub trait StepExecutor: Send + Sync {
    /// Execute step
    async fn execute_step(
        &self,
        step: &WorkflowStep,
        context: &WorkflowContext,
        workflow_instance: &WorkflowInstance,
    ) -> Result<StepExecutionResult>;
    
    /// Validate step
    async fn validate_step(&self, step: &WorkflowStep) -> Result<()>;
    
    /// Get step capabilities
    fn get_capabilities(&self) -> Vec<String>;
}

/// Step execution result
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct StepExecutionResult {
    /// Execution success
    pub success: bool,
    
    /// Execution result
    pub result: serde_json::Value,
    
    /// Execution duration
    pub duration: Duration,
    
    /// Execution errors
    pub errors: Vec<String>,
    
    /// Execution metadata
    pub metadata: HashMap<String, serde_json::Value>,
    
    /// Execution metrics
    pub metrics: StepMetrics,
}

/// Workflow execution state
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct WorkflowExecutionState {
    /// Current status
    pub status: WorkflowStatus,
    
    /// Current step
    pub current_step: Option<String>,
    
    /// Execution stack
    pub execution_stack: Vec<String>,
    
    /// Completed steps
    pub completed_steps: HashSet<String>,
    
    /// Failed steps
    pub failed_steps: HashMap<String, String>,
    
    /// Execution context
    pub context: WorkflowContext,
    
    /// Execution start time
    pub started_at: DateTime<Utc>,
    
    /// Execution end time
    pub ended_at: Option<DateTime<Utc>>,
}

/// Workflow execution result
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct WorkflowExecutionResult {
    /// Execution success
    pub success: bool,
    
    /// Execution result
    pub result: serde_json::Value,
    
    /// Execution duration
    pub duration: Duration,
    
    /// Step results
    pub step_results: HashMap<String, serde_json::Value>,
    
    /// Execution errors
    pub errors: Vec<String>,
    
    /// Execution metadata
    pub metadata: HashMap<String, serde_json::Value>,
    
    /// Execution metrics
    pub metrics: WorkflowExecutionMetrics,
}

