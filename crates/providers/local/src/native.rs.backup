    /// Process classification request
    async fn process_classification(
        request: &UniversalAIRequest,
        _config: &NativeAIConfig,
    ) -> ProviderResult<UniversalAIResponse> {
        debug!("Processing classification request");

        // Extract text from request
        let text = request.input.get("text")
            .and_then(|v| v.as_str())
            .ok_or_else(|| ProviderError::InvalidRequest("Missing text".to_string()))?;

        // Simulate classification
        tokio::time::sleep(Duration::from_millis(60)).await;

        // Generate mock classification
        let classification = if text.contains("error") || text.contains("problem") {
            "negative"
        } else if text.contains("good") || text.contains("excellent") {
            "positive"
        } else {
            "neutral"
        };

        let confidence = 0.87;

        let response = UniversalAIResponse {
            request_id: request.request_id.clone(),
            response_type: request.request_type.clone(),
            content: serde_json::json!({
                "classification": classification,
                "confidence": confidence,
                "classes": ["positive", "negative", "neutral"],
            }),
            metadata: serde_json::json!({
                "processing_time_ms": 60,
                "text_length": text.len(),
            }),
            usage: Some(serde_json::json!({
                "prompt_tokens": text.len() / 4,
                "total_tokens": text.len() / 4,
            })),
            error: None,
        };

        Ok(response)
    }

    /// Process summarization request
    async fn process_summarization(
        request: &UniversalAIRequest,
        config: &NativeAIConfig,
    ) -> ProviderResult<UniversalAIResponse> {
        debug!("Processing summarization request");

        // Extract text from request
        let text = request.input.get("text")
            .and_then(|v| v.as_str())
            .ok_or_else(|| ProviderError::InvalidRequest("Missing text".to_string()))?;

        // Simulate summarization
        tokio::time::sleep(Duration::from_millis(120)).await;

        // Generate mock summary
        let summary = if text.len() > 100 {
            format!("Summary of text ({}): {}", text.len(), &text[..100])
        } else {
            format!("Summary: {}", text)
        };

        let response = UniversalAIResponse {
            request_id: request.request_id.clone(),
            response_type: request.request_type.clone(),
            content: serde_json::json!({
                "summary": summary,
                "model": config.model_config.model_type,
                "compression_ratio": 0.3,
            }),
            metadata: serde_json::json!({
                "processing_time_ms": 120,
                "original_length": text.len(),
                "summary_length": summary.len(),
            }),
            usage: Some(serde_json::json!({
                "prompt_tokens": text.len() / 4,
                "completion_tokens": summary.len() / 4,
                "total_tokens": text.len() / 4 + summary.len() / 4,
            })),
            error: None,
        };

        Ok(response)
    }

    /// Process translation request
    async fn process_translation(
        request: &UniversalAIRequest,
        config: &NativeAIConfig,
    ) -> ProviderResult<UniversalAIResponse> {
        debug!("Processing translation request");

        // Extract text and target language from request
        let text = request.input.get("text")
            .and_then(|v| v.as_str())
            .ok_or_else(|| ProviderError::InvalidRequest("Missing text".to_string()))?;

        let target_language = request.input.get("target_language")
            .and_then(|v| v.as_str())
            .unwrap_or("en");

        // Simulate translation
        tokio::time::sleep(Duration::from_millis(150)).await;

        // Generate mock translation
        let translation = format!("Translated to {}: {}", target_language, text);

        let response = UniversalAIResponse {
            request_id: request.request_id.clone(),
            response_type: request.request_type.clone(),
            content: serde_json::json!({
                "translation": translation,
                "source_language": "auto",
                "target_language": target_language,
                "model": config.model_config.model_type,
                "confidence": 0.91,
            }),
            metadata: serde_json::json!({
                "processing_time_ms": 150,
                "character_count": text.len(),
            }),
            usage: Some(serde_json::json!({
                "prompt_tokens": text.len() / 4,
                "completion_tokens": translation.len() / 4,
                "total_tokens": text.len() / 4 + translation.len() / 4,
            })),
            error: None,
        };

        Ok(response)
    }

    /// Process question answering request
    async fn process_question_answering(
        request: &UniversalAIRequest,
        config: &NativeAIConfig,
    ) -> ProviderResult<UniversalAIResponse> {
        debug!("Processing question answering request");

        // Extract question and context from request
        let question = request.input.get("question")
            .and_then(|v| v.as_str())
            .ok_or_else(|| ProviderError::InvalidRequest("Missing question".to_string()))?;

        let context = request.input.get("context")
            .and_then(|v| v.as_str())
            .unwrap_or("");

        // Simulate question answering
        tokio::time::sleep(Duration::from_millis(200)).await;

        // Generate mock answer
        let answer = format!("Answer to '{}': Based on the context, the answer is derived from the provided information.", question);

        let response = UniversalAIResponse {
            request_id: request.request_id.clone(),
            response_type: request.request_type.clone(),
            content: serde_json::json!({
                "answer": answer,
                "question": question,
                "context_used": !context.is_empty(),
                "model": config.model_config.model_type,
                "confidence": 0.88,
            }),
            metadata: serde_json::json!({
                "processing_time_ms": 200,
                "question_length": question.len(),
                "context_length": context.len(),
            }),
            usage: Some(serde_json::json!({
                "prompt_tokens": (question.len() + context.len()) / 4,
                "completion_tokens": answer.len() / 4,
                "total_tokens": (question.len() + context.len() + answer.len()) / 4,
            })),
            error: None,
        };

        Ok(response)
    }

    /// Process code generation request
    async fn process_code_generation(
        request: &UniversalAIRequest,
        config: &NativeAIConfig,
    ) -> ProviderResult<UniversalAIResponse> {
        debug!("Processing code generation request");

        // Extract prompt and language from request
        let prompt = request.input.get("prompt")
            .and_then(|v| v.as_str())
            .ok_or_else(|| ProviderError::InvalidRequest("Missing prompt".to_string()))?;

        let language = request.input.get("language")
            .and_then(|v| v.as_str())
            .unwrap_or("python");

        // Simulate code generation
        tokio::time::sleep(Duration::from_millis(300)).await;

        // Generate mock code
        let code = match language {
            "python" => format!("# Generated Python code for: {}\ndef generated_function():\n    return 'Hello, World!'", prompt),
            "rust" => format!("// Generated Rust code for: {}\nfn generated_function() -> String {{\n    \"Hello, World!\".to_string()\n}}", prompt),
            "javascript" => format!("// Generated JavaScript code for: {}\nfunction generatedFunction() {{\n    return 'Hello, World!';\n}}", prompt),
            _ => format!("// Generated code for: {}\n// Language: {}\nfunction generated() {{ return 'Hello, World!'; }}", prompt, language),
        };

        let response = UniversalAIResponse {
            request_id: request.request_id.clone(),
            response_type: request.request_type.clone(),
            content: serde_json::json!({
                "code": code,
                "language": language,
                "model": config.model_config.model_type,
                "explanation": format!("Generated {} code based on the prompt", language),
            }),
            metadata: serde_json::json!({
                "processing_time_ms": 300,
                "prompt_length": prompt.len(),
                "code_length": code.len(),
            }),
            usage: Some(serde_json::json!({
                "prompt_tokens": prompt.len() / 4,
                "completion_tokens": code.len() / 4,
                "total_tokens": prompt.len() / 4 + code.len() / 4,
            })),
            error: None,
        };

        Ok(response)
    }

    /// Get current health status
    pub async fn get_health(&self) -> ProviderHealth {
        self.health.read().await.clone()
    }

    /// Get current metrics
    pub async fn get_metrics(&self) -> PerformanceMetrics {
        self.metrics.read().await.clone()
    }

    /// Get available models
    pub async fn get_available_models(&self) -> ProviderResult<Vec<ModelInfo>> {
        Ok(vec![
            ModelInfo {
                model_id: self.config.model_config.model_type.clone(),
                name: format!("Native AI Model ({})", self.config.model_config.model_type),
                description: "Native AI model with local processing".to_string(),
                capabilities: self.config.capabilities.clone(),
                provider: "native".to_string(),
                version: "1.0.0".to_string(),
                cost_per_token: 0.0, // Native models have no per-token cost
                max_requests_per_minute: 60,
                status: "active".to_string(),
            }
        ])
    }

    /// Estimate cost for a request
    pub async fn estimate_cost(&self, _request: &UniversalAIRequest) -> ProviderResult<CostEstimate> {
        // Native models don't have per-request costs
        Ok(CostEstimate {
            estimated_cost: 0.0,
            currency: "USD".to_string(),
            breakdown: serde_json::json!({
                "base_cost": 0.0,
                "prompt_tokens": 0,
                "completion_tokens": 0,
                "total_tokens": 0,
                "note": "Native AI processing has no per-request costs"
            }),
        })
    }
}

#[async_trait]
impl crate::UniversalAIProvider for NativeAIProvider {
    async fn process_request(&self, request: UniversalAIRequest) -> ProviderResult<UniversalAIResponse> {
        // Add request to queue
        let (tx, rx) = tokio::sync::oneshot::channel();
        let queued_request = QueuedRequest {
            request,
            response_sender: tx,
            queued_at: Instant::now(),
        };

        {
            let mut queue = self.request_queue.lock().await;
            queue.push(queued_request);
        }

        // Wait for response
        match rx.await {
            Ok(result) => result,
            Err(_) => Err(ProviderError::RequestTimeout),
        }
    }

    async fn stream_request(&self, _request: UniversalAIRequest) -> ProviderResult<UniversalAIStream> {
        // TODO: Implement streaming for native AI
        Err(ProviderError::NotImplemented("Streaming not yet implemented for native AI".to_string()))
    }

    async fn health_check(&self) -> ProviderResult<ProviderHealth> {
        Ok(self.get_health().await)
    }

    async fn get_models(&self) -> ProviderResult<Vec<ModelInfo>> {
        self.get_available_models().await
    }

    async fn estimate_cost(&self, request: &UniversalAIRequest) -> ProviderResult<CostEstimate> {
        self.estimate_cost(request).await
    }

    fn name(&self) -> &str {
        "native-ai"
    }

    fn provider_type(&self) -> crate::ProviderType {
        crate::ProviderType::Local
    }
}

#[cfg(test)]
mod tests {
    use super::*;
    use crate::types::AIRequestType;

    #[tokio::test]
    async fn test_native_ai_provider_creation() {
        let config = NativeAIConfig::default();
        let provider = NativeAIProvider::new(config);
        
        assert_eq!(provider.name(), "native-ai");
        assert_eq!(provider.provider_type(), crate::ProviderType::Local);
    }

    #[tokio::test]
    async fn test_native_ai_provider_initialization() {
        let config = NativeAIConfig::default();
        let provider = NativeAIProvider::new(config);
        
        let result = provider.initialize().await;
        assert!(result.is_ok());
        
        let health = provider.get_health().await;
        assert!(health.is_healthy);
    }

    #[tokio::test]
    async fn test_text_generation_request() {
        let config = NativeAIConfig::default();
        let provider = NativeAIProvider::new(config);
        provider.initialize().await.unwrap();

        let request = UniversalAIRequest {
            request_id: "test-001".to_string(),
            request_type: AIRequestType::TextGeneration,
            input: serde_json::json!({
                "prompt": "Hello, world!"
            }),
            metadata: RequestMetadata::default(),
            streaming: None,
        };

        let result = provider.process_request(request).await;
        assert!(result.is_ok());
        
        let response = result.unwrap();
        assert_eq!(response.request_id, "test-001");
        assert!(response.content.get("text").is_some());
    }

    #[tokio::test]
    async fn test_model_listing() {
        let config = NativeAIConfig::default();
        let provider = NativeAIProvider::new(config);
        provider.initialize().await.unwrap();

        let models = provider.get_models().await.unwrap();
        assert_eq!(models.len(), 1);
        assert_eq!(models[0].provider, "native");
    }

    #[tokio::test]
    async fn test_cost_estimation() {
        let config = NativeAIConfig::default();
        let provider = NativeAIProvider::new(config);

        let request = UniversalAIRequest {
            request_id: "test-cost".to_string(),
            request_type: AIRequestType::TextGeneration,
            input: serde_json::json!({
                "prompt": "Test prompt"
            }),
            metadata: RequestMetadata::default(),
            streaming: None,
        };

        let cost = provider.estimate_cost(&request).await.unwrap();
        assert_eq!(cost.estimated_cost, 0.0);
        assert_eq!(cost.currency, "USD");
    }

    #[tokio::test]
    async fn test_health_check() {
        let config = NativeAIConfig::default();
        let provider = NativeAIProvider::new(config);
        provider.initialize().await.unwrap();

        let health = provider.health_check().await.unwrap();
        assert!(health.is_healthy);
        assert_eq!(health.error_count, 0);
    }
} 