        debug!("Processing text completion request");

        // Extract text from request
        let text = request.input.get("text")
            .and_then(|v| v.as_str())
            .ok_or_else(|| ProviderError::InvalidRequest("Missing text".to_string()))?;

        // Simulate AI processing
        tokio::time::sleep(Duration::from_millis(80)).await;

        // Generate completion
        let completion = format!("{} [COMPLETED]", text);

        let response = UniversalAIResponse {
            request_id: request.request_id.clone(),
            response_type: request.request_type.clone(),
            content: serde_json::json!({
                "completion": completion,
