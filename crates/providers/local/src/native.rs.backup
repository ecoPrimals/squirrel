    }

    /// Process embedding request
    async fn process_embedding(
        request: &UniversalAIRequest,
        config: &NativeAIConfig,
    ) -> ProviderResult<UniversalAIResponse> {
        debug!("Processing embedding request");

        // Extract text from request
        let text = request.input.get("text")
            .and_then(|v| v.as_str())
            .ok_or_else(|| ProviderError::InvalidRequest("Missing text".to_string()))?;

        // Simulate embedding generation
        tokio::time::sleep(Duration::from_millis(50)).await;

        // Generate mock embedding (replace with actual embedding)
        let embedding: Vec<f32> = (0..384).map(|i| (i as f32 * 0.001) % 1.0).collect();

        let response = UniversalAIResponse {
            request_id: request.request_id.clone(),
