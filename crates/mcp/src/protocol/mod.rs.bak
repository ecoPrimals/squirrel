//! MCP Protocol module for machine context exchange.
//!
//! This module implements the core protocol functionality for the Machine Context Protocol (MCP),
//! providing a robust framework for message handling, state management, and command execution
//! between components in a distributed system.
//!
//! The MCP protocol is designed to facilitate secure, efficient communication with:
//! - Message format validation
//! - Protocol state management
//! - Command routing and execution
//! - Security integration
//! - Error handling and recovery
//!
//! # Core Components
//!
//! The key components in this module include:
//!
//! - [`MCPProtocolBase`]: Base implementation of the protocol
//! - [`MCPProtocolAdapter`]: Thread-safe adapter providing a clean interface
//! - [`CommandHandler`]: Trait for handling command messages
//! - [`MCPProtocol`]: Interface for protocol operations
//!
//! # Examples
//!
//! Creating and using the MCP protocol:
//!
//! ```
//! use squirrel_mcp::protocol::{MCPProtocolBase, ProtocolConfig};
//! use squirrel_mcp::MCPMessage;
//! use squirrel_mcp::ProtocolMessageType as MessageType;
//! use squirrel_mcp::protocol::MessageId;
//! use serde_json::json;
//!
//! // Create a new protocol instance
//! let protocol = MCPProtocolBase::new_default();
//!
//! // Create a message (simplified for example)
//! let message = MCPMessage {
//!     id: MessageId("msg123".to_string()),
//!     type_: MessageType::Command,
//!     payload: json!({"command": "status"}),
//!     metadata: json!({}),
//!     security: json!({}),
//!     timestamp: chrono::Utc::now(),
//!     version: "1.0".to_string(),
//! };
//! ```
//!
//! Using the protocol adapter:
//!
//! ```
//! use squirrel_mcp::protocol::{create_protocol_adapter, MCPProtocol};
//! use std::sync::Arc;
//! use serde_json::Value;
//!
//! # #[tokio::main]
//! # async fn main() -> Result<(), Box<dyn std::error::Error>> {
//! // Create a protocol adapter
//! let adapter = create_protocol_adapter();
//! 
//! // Initialize the adapter
//! adapter.initialize().await?;
//! 
//! // Create a message
//! let message = MCPMessage {
//!     id: MessageId("msg123".to_string()),
//!     type_: MessageType::Command,
//!     payload: json!({"command": "status"}),
//!     metadata: json!({}).into(),
//!     security: Default::default(),
//!     timestamp: chrono::Utc::now(),
//!     version: ProtocolTypesProtocolVersion::new(1, 0),
//!     trace_id: Some(uuid::Uuid::new_v4().to_string()),
//! };
//! 
//! // Check protocol state
//! let state = adapter.get_state().await;
//! # Ok(())
//! # }
//! ```

use crate::error::{MCPError, ProtocolError, Result as MCPResult};
use serde::{Deserialize, Serialize};
use serde_json::{json, Value};
use std::{collections::HashMap, fmt::Debug};

/// Protocol-related types module
pub mod types;

// Re-export specific types from the protocol::types module - make them available from crate::protocol
pub use types::{
    MCPMessage,
    MessageId,
    MessageType,
    Header,
    ProtocolVersion,
};

/// Protocol-specific result type for operations that return a response.
///
/// This type is an alias for `Result<MCPResponse>` and is used throughout
/// the protocol module for operations that produce a response message.
pub type ProtocolResult = MCPResult<crate::types::MCPResponse>;

/// Result type for validation operations.
///
/// This type is an alias for `Result<()>` and is used for operations
/// that validate messages without producing a response.
pub type ValidationResult = MCPResult<()>;

/// Describes the outcome of a message routing attempt.
#[derive(Debug, Clone, PartialEq, Eq)]
pub enum RoutingDecision {
    /// Route the message to a specific handler identified by its key (usually message type).
    RouteToHandler(String),
    /// Broadcast the message to all applicable handlers (typically for events).
    Broadcast,
    /// No appropriate handler or route was found for the message.
    NoRouteFound,
}

/// Result type for message routing operations.
///
/// This type is an alias for `Result<RoutingDecision>` and is used for operations
/// that route messages to their appropriate handlers.
pub type RoutingResult = MCPResult<RoutingDecision>;

/// Adapter module for protocol operations
///
/// ```
/// use squirrel_mcp::protocol::adapter::{create_protocol_adapter, MCPProtocolAdapter};
/// use squirrel_mcp::protocol::types::MessageId;
/// use squirrel_mcp::MCPMessage;
/// use squirrel_mcp::ProtocolMessageType as MessageType;
/// use squirrel_mcp::ProtocolTypesProtocolVersion;
/// use serde_json::json;
/// use chrono::Utc;
///
/// async fn example() {
///     let adapter = create_protocol_adapter();
///     adapter.initialize().await.expect("Failed to initialize");
///     
///     let message = MCPMessage {
///         id: MessageId("msg123".to_string()),
///         type_: MessageType::Command,
///         payload: json!({"command": "status"}),
///         metadata: json!({}).into(),
///         security: Default::default(),
///         timestamp: Utc::now(),
///         version: ProtocolTypesProtocolVersion::new(1, 0),
///         trace_id: Some(uuid::Uuid::new_v4().to_string()),
///     };
///     
///     let response = adapter.handle_message(message).await;
/// }
/// ```
pub mod adapter;
pub use adapter::{
    create_protocol_adapter, create_protocol_adapter_with_protocol, MCPProtocolAdapter,
};

/// Wire format adapter for protocol serialization/deserialization
///
/// The wire format adapter is responsible for converting between domain objects and
/// wire format messages, providing a consistent serialization/deserialization
/// mechanism for the protocol.
///
/// ```rust,no_run
/// use squirrel_mcp::protocol::adapter_wire::{WireFormatAdapter, WireFormatConfig};
/// use squirrel_mcp::protocol::{DomainObject, WireMessage};
/// use serde_json::json;
///
/// # async fn example() -> Result<(), Box<dyn std::error::Error>> {
/// // Create a configuration for the wire format adapter
/// let config = WireFormatConfig::default();
///
/// // Create an adapter with the configuration
/// let adapter = WireFormatAdapter::new(config);
///
/// // Create a domain object (implementing the DomainObject trait)
/// struct MyDomainObject {
///     type_name: String,
///     content: serde_json::Value,
///     version: String,
/// }
///
/// impl DomainObject for MyDomainObject {
///     fn get_type(&self) -> &str {
///         &self.type_name
///     }
///
///     fn get_content(&self) -> &serde_json::Value {
///         &self.content
///     }
///
///     fn get_version(&self) -> &str {
///         &self.version
///     }
/// }
///
/// let domain_object = MyDomainObject {
///     type_name: "user".to_string(),
///     content: json!({"name": "John", "email": "john@example.com"}),
///     version: "1.0".to_string(),
/// };
///
/// // Convert to wire format
/// let wire_message = adapter.to_wire_format(&domain_object).await?;
///
/// // Convert back to domain object (using a conversion function in a real app)
/// let type_name = wire_message.message_type.clone();
/// let content = wire_message.content.clone();
/// let version = wire_message.version.clone();
///
/// // Verify the conversion worked
/// assert_eq!(domain_object.type_name, type_name);
/// # Ok(())
/// # }
/// ```
pub mod adapter_wire;
pub use adapter_wire::{
    WireFormatAdapter, WireFormatConfig, WireMessage, WireFormat, WireProtocolVersion, DomainObject
};

/// Domain object implementations for protocol serialization/deserialization
pub mod domain_objects;

