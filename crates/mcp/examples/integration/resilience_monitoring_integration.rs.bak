//! Resilience Monitoring Integration Example
//!
//! This example demonstrates the integration between MCP's resilience framework and monitoring system.
//! It shows how to create a health monitoring bridge that connects health checks with
//! alerts and recovery mechanisms.

use std::collections::HashMap;
use std::sync::{Arc, Mutex};
use std::time::Duration;
use std::error::Error as StdError;
use std::result::Result as StdResult;
use tokio::runtime;
use async_trait::async_trait;
use tracing::{info, warn, error, Level};
use tracing_subscriber;

// MCP imports
use squirrel_mcp::error::MCPError;
use squirrel_mcp::resilience::health::{
    HealthCheck, HealthCheckConfig, HealthCheckResult, HealthStatus, HealthMonitor
};
use squirrel_mcp::resilience::recovery::{RecoveryStrategy, FailureInfo, FailureSeverity};
use squirrel_mcp::monitoring::alerts::{
    Alert, AlertConfiguration, AlertState, AlertAction, AlertCondition, AlertSeverity, AlertManager
};
use squirrel_mcp::monitoring::metrics::MetricsCollector;
use squirrel_mcp::integration::{
    HealthMonitoringBridge, HealthMonitoringBridgeConfig
};

/// Example service that can be monitored
struct ApiService {
    name: String,
    status: Arc<Mutex<HealthStatus>>,
    response_time: Arc<Mutex<f64>>,
    error_rate: Arc<Mutex<f64>>,
}

impl ApiService {
    fn new(name: &str) -> Self {
        Self {
            name: name.to_string(),
            status: Arc::new(Mutex::new(HealthStatus::Healthy)),
            response_time: Arc::new(Mutex::new(50.0)),
            error_rate: Arc::new(Mutex::new(0.0)),
        }
    }
    
    fn degrade_service(&self, error_rate: f64, response_time: f64) {
        *self.error_rate.lock().unwrap() = error_rate;
        *self.response_time.lock().unwrap() = response_time;
        
        let status = if error_rate > 0.2 || response_time > 400.0 {
            HealthStatus::Unhealthy
        } else if error_rate > 0.05 || response_time > 200.0 {
            HealthStatus::Degraded
        } else {
            HealthStatus::Healthy
        };
        
        *self.status.lock().unwrap() = status;
        info!("Service {} status changed to {:?}", self.name, status);
    }
    
    fn recover_service(&self) {
        *self.error_rate.lock().unwrap() = 0.0;
        *self.response_time.lock().unwrap() = 50.0;
        *self.status.lock().unwrap() = HealthStatus::Healthy;
        info!("Service {} recovered to healthy state", self.name);
    }
}

/// Health check implementation for the API service
struct ApiServiceHealthCheck {
    service: Arc<ApiService>,
    config: HealthCheckConfig,
}

impl ApiServiceHealthCheck {
    fn new(service: Arc<ApiService>) -> Self {
        Self {
            service,
            config: HealthCheckConfig {
                check_interval: Duration::from_secs(60),
                check_timeout: Duration::from_secs(5),
                failure_threshold: 3,
                recovery_threshold: 2,
                auto_recovery: true,
            },
        }
    }
}

#[async_trait]
impl HealthCheck for ApiServiceHealthCheck {
    fn id(&self) -> &str {
        &self.service.name
    }
    
    fn config(&self) -> &HealthCheckConfig {
        &self.config
    }
    
    fn config_mut(&mut self) -> &mut HealthCheckConfig {
        &mut self.config
    }
    
    async fn check(&self) -> HealthCheckResult {
        let status = *self.service.status.lock().unwrap();
        let response_time = *self.service.response_time.lock().unwrap();
        let error_rate = *self.service.error_rate.lock().unwrap();
        
        let mut result = HealthCheckResult::new(
            self.service.name.clone(), 
            status,
            format!("{} health check completed with status {:?}", self.service.name, status)
        );
        
        // Add metrics
        result = result.with_metric("response_time_ms", response_time);
        result = result.with_metric("error_rate", error_rate);
        
        result
    }
}

/// Custom service recovery handler
struct ServiceRecoveryHandler {
    services: HashMap<String, Arc<ApiService>>,
}

impl ServiceRecoveryHandler {
    fn new() -> Self {
        Self {
            services: HashMap::new(),
        }
    }
    
    fn register_service(&mut self, service: Arc<ApiService>) {
        self.services.insert(service.name.clone(), service);
    }
    
    fn recover_service(&self, service_name: &str) -> Result<(), MCPError> {
        if let Some(service) = self.services.get(service_name) {
            info!("Recovering service {}", service_name);
            service.recover_service();
            Ok(())
        } else {
            error!("Unknown service: {}", service_name);
            Err(MCPError::NotFound(format!("Service {} not found", service_name)))
        }
    }
}

/// Initialize MCP components for the integration demo
async fn setup_integration() -> StdResult<(
    Arc<HealthMonitor>,
    Arc<HealthMonitoringBridge>,
    Arc<Mutex<RecoveryStrategy>>,
    Arc<ServiceRecoveryHandler>
), Box<dyn StdError>> {
    // Create recovery handler
    let mut recovery_handler = ServiceRecoveryHandler::new();
    
    // Create example services
    let api_service = Arc::new(ApiService::new("api_service"));
    let db_service = Arc::new(ApiService::new("db_service"));
    
    // Register services with recovery handler
    recovery_handler.register_service(api_service.clone());
    recovery_handler.register_service(db_service.clone());
    
    let recovery_handler = Arc::new(recovery_handler);
    
    // Create MCP components
    let health_monitor = Arc::new(HealthMonitor::new(100)); // 100 is the max history size
    let metrics_collector = Arc::new(MetricsCollector::new());
    let alert_manager = Arc::new(AlertManager::new());
    let recovery_strategy = Arc::new(Mutex::new(RecoveryStrategy::default()));
    
    // Register health checks with the monitor
    let api_health_check = Box::new(ApiServiceHealthCheck::new(api_service.clone()));
    let db_health_check = Box::new(ApiServiceHealthCheck::new(db_service.clone()));
    
    health_monitor.register(api_health_check).map_err(|e| Box::new(e) as Box<dyn StdError>)?;
    health_monitor.register(db_health_check).map_err(|e| Box::new(e) as Box<dyn StdError>)?;
    
    // Configure the health monitoring bridge
    let bridge_config = HealthMonitoringBridgeConfig {
        forward_interval: 5,
        forward_all_components: true,
        bidirectional: true,
        log_level: None,
    };
    
    // Create and start the bridge
    let bridge = Arc::new(HealthMonitoringBridge::new(
        health_monitor.clone(),
        metrics_collector.clone(),
        alert_manager.clone(),
        bridge_config,
    ));
    
    // Setup recovery strategy with handler
    {
        let mut strategy = recovery_strategy.lock().unwrap();
        let api_recovery = recovery_handler.clone();
        
        // Setup recovery action for api_service
        let result = strategy.handle_failure(
            "api_service".to_string(),
            FailureInfo {
                message: "API service failure".to_string(),
                severity: FailureSeverity::Minor,
                context: "health_check".to_string(),
                recovery_attempts: 0,
            },
            move || {
                match api_recovery.recover_service("api_service") {
                    Ok(()) => Ok(()),
                    Err(e) => Err(Box::new(e) as Box<dyn StdError>),
                }
            }
        );
        
        if let Err(e) = result {
            warn!("Failed to set up API service recovery: {:?}", e);
        }
        
        // Setup recovery action for db_service
        let db_recovery = recovery_handler.clone();
        let result = strategy.handle_failure(
            "db_service".to_string(),
            FailureInfo {
                message: "DB service failure".to_string(),
                severity: FailureSeverity::Minor,
                context: "health_check".to_string(),
                recovery_attempts: 0,
            },
            move || {
                match db_recovery.recover_service("db_service") {
                    Ok(()) => Ok(()),
                    Err(e) => Err(Box::new(e) as Box<dyn StdError>),
                }
            }
        );
        
        if let Err(e) = result {
            warn!("Failed to set up DB service recovery: {:?}", e);
        }
    }
    
    // Start the bridge
    bridge.start().await.map_err(|e| Box::new(e) as Box<dyn StdError>)?;
    
    Ok((health_monitor, bridge, recovery_strategy, recovery_handler))
}

/// Execute the integration demonstration
async fn run_integration_demo() -> StdResult<(), Box<dyn StdError>> {
    // Initialize tracing for better logging
    tracing_subscriber::fmt()
        .with_max_level(Level::DEBUG)
        .init();
    
    info!("Starting resilience-monitoring integration example");
    
    // Set up the integrated components
    let (health_monitor, bridge, recovery_strategy, recovery_handler) = 
        setup_integration().await?;
    
    // Simulate normal operation
    info!("Simulating normal operation for 2 seconds");
    tokio::time::sleep(Duration::from_secs(2)).await;
    
    // Create some artificial service degradation
    let api_service = recovery_handler.services.get("api_service").unwrap();
    api_service.degrade_service(0.1, 150.0);
    
    info!("API service slightly degraded, monitoring for 2 seconds");
    tokio::time::sleep(Duration::from_secs(2)).await;
    
    // Further degrade the service to trigger recovery
    api_service.degrade_service(0.25, 450.0);
    
    info!("API service severely degraded, monitoring for 5 seconds");
    info!("The monitoring system should detect the degradation and trigger recovery");
    tokio::time::sleep(Duration::from_secs(5)).await;
    
    // Degrade the DB service while API recovers
    let db_service = recovery_handler.services.get("db_service").unwrap();
    db_service.degrade_service(0.2, 350.0);
    
    info!("DB service degraded, monitoring for 5 seconds");
    tokio::time::sleep(Duration::from_secs(5)).await;
    
    // Stop the bridge
    info!("Stopping the monitoring bridge");
    bridge.stop().await.map_err(|e| Box::new(e) as Box<dyn StdError>)?;
    
    info!("Resilience-monitoring integration example completed");
    
    Ok(())
}

/// Error handling function for integration errors
async fn handle_integration_error(error: Box<dyn StdError>) {
    error!("Integration error occurred: {}", error);
    
    // For MCPError types, provide more specific error information
    if let Some(mcp_error) = error.downcast_ref::<MCPError>() {
        match mcp_error {
            MCPError::Timeout(desc) => {
                warn!("Timeout occurred: {}. Consider increasing timeout settings.", desc);
            },
            MCPError::InvalidState(desc) => {
                error!("Invalid state: {}. The system might need to be restarted.", desc);
            },
            MCPError::NotFound(desc) => {
                warn!("Resource not found: {}. Check if the component exists.", desc);
            },
            _ => {
                error!("Unexpected MCP error: {:?}", mcp_error);
            }
        }
    } else {
        error!("Non-MCP error: {}", error);
    }
}

/// Main function
fn main() -> StdResult<(), Box<dyn StdError>> {
    // Initialize the tokio runtime for async execution
    let rt = runtime::Builder::new_multi_thread()
        .enable_all()
        .build()
        .expect("Failed to create runtime");

    // Execute the integration demo asynchronously
    match rt.block_on(run_integration_demo()) {
        Ok(_) => {
            info!("Integration demo completed successfully");
            Ok(())
        }
        Err(err) => {
            // Convert any error into a Box<dyn StdError>
            error!("Integration demo failed: {}", err);
            rt.block_on(handle_integration_error(err));
            Ok(()) // We log the error but return Ok() since this is just a demo
        }
    }
} 