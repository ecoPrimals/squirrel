async fn create_test_squirrel_registry() -> SquirrelRegistry {
    let registry = SquirrelRegistry::new();

    // Add some test nodes
    let node1 = SquirrelNode {
        id: "test-gpu-1".to_string(),
        name: "Test GPU Node 1".to_string(),
        endpoint: "https://test-gpu-1.example.com".to_string(),
        capabilities: HashMap::new(),
        status: NodeStatus::Online,
        priority: 95,
        region: Some("us-west-2".to_string()),
        tags: vec!["gpu".to_string(), "test".to_string()],
    };

    let node2 = SquirrelNode {
        id: "test-edge-1".to_string(),
        name: "Test Edge Node 1".to_string(),
        endpoint: "https://test-edge-1.example.com".to_string(),
        capabilities: HashMap::new(),
        status: NodeStatus::Online,
        priority: 70,
        region: Some("us-east-1".to_string()),
        tags: vec!["edge".to_string(), "test".to_string()],
    };

    registry.register_node(node1).await.unwrap();
    registry.register_node(node2).await.unwrap();

    registry
}

#[tokio::test]
async fn test_end_to_end_routing_flow() {
    let router = create_test_router_with_providers().await;
    let squirrel_registry = Arc::new(create_test_squirrel_registry().await);

    let api_state = ApiState {
        router: Arc::new(router),
        squirrel_registry,
    };

    // Test that we have the expected nodes
    let nodes = api_state.squirrel_registry.list_nodes().await;
    assert_eq!(nodes.len(), 2);

    // Test finding capable nodes for a task
    let task = AITask {
        task_type: TaskType::TextGeneration,
        required_model_type: None,
        min_context_size: None,
        requires_streaming: false,
        requires_function_calling: false,
        requires_tool_use: false,
        security_requirements: SecurityRequirements::default(),
        complexity_score: Some(90),
        priority: 95,
    };

    let capable_nodes = api_state.squirrel_registry.find_capable_nodes(&task).await;
    // In this test, nodes don't have capabilities defined, so this would be empty
    // In a real implementation, you'd populate capabilities and test matching
    assert!(capable_nodes.len() >= 0);
}
