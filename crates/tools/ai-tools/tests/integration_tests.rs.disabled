#[tokio::test]
async fn test_provider_registry_creation() {
    let registry = ProviderPluginRegistry::new();

    // Test that built-in providers are registered
    let provider_types = registry.list_provider_types();
    assert!(provider_types.contains(&"openrouter".to_string()));
    assert!(provider_types.contains(&"llamacpp".to_string()));
    assert!(provider_types.contains(&"huggingface".to_string()));
}

#[tokio::test]
async fn test_openrouter_provider_creation() {
    let mut registry = ProviderPluginRegistry::new();

    let config = ProviderConfig {
        provider_type: "openrouter".to_string(),
        name: "test_openrouter".to_string(),
        enabled: true,
        priority: 80,
        settings: {
            let mut settings = HashMap::new();
            settings.insert("api_key".to_string(), json!("test-key"));
            settings.insert("app_name".to_string(), json!("Test App"));
            settings.insert("site_url".to_string(), json!("https://test.com"));
            settings
        },
        rate_limits: None,
        retry_config: None,
    };

    let result = registry.create_provider(config).await;
    assert!(result.is_ok());

    let provider = result.unwrap();
    assert_eq!(provider.plugin().name(), "OpenRouter");
    assert_eq!(provider.plugin().version(), "1.0.0");

    // Test supported models
    let models = provider.plugin().supported_models();
    assert!(!models.is_empty());
}

#[tokio::test]
async fn test_llamacpp_provider_creation() {
    let mut registry = ProviderPluginRegistry::new();

    let config = ProviderConfig {
        provider_type: "llamacpp".to_string(),
        name: "test_llamacpp".to_string(),
        enabled: true,
        priority: 90,
        settings: {
            let mut settings = HashMap::new();
            settings.insert("endpoint".to_string(), json!("http://localhost:8080"));
            settings.insert("model_name".to_string(), json!("test-model"));
            settings.insert("context_size".to_string(), json!(4096));
            settings
        },
        rate_limits: None,
        retry_config: None,
    };

    let result = registry.create_provider(config).await;
    assert!(result.is_ok());

    let provider = result.unwrap();
    assert_eq!(provider.plugin().name(), "llama.cpp");
    assert_eq!(provider.plugin().version(), "1.0.0");
}

#[tokio::test]
async fn test_huggingface_provider_creation() {
    let mut registry = ProviderPluginRegistry::new();

    let config = ProviderConfig {
        provider_type: "huggingface".to_string(),
        name: "test_huggingface".to_string(),
        enabled: true,
        priority: 70,
        settings: {
            let mut settings = HashMap::new();
            settings.insert("api_key".to_string(), json!("test-key"));
            settings.insert(
                "default_model".to_string(),
                json!("microsoft/DialoGPT-medium"),
            );
            settings
        },
        rate_limits: None,
        retry_config: None,
    };

    let result = registry.create_provider(config).await;
    assert!(result.is_ok());

    let provider = result.unwrap();
    assert_eq!(provider.plugin().name(), "Hugging Face");
    assert_eq!(provider.plugin().version(), "1.0.0");

    // Test supported models
    let models = provider.plugin().supported_models();
    assert!(!models.is_empty());

    // Check for popular models
    let model_ids: Vec<String> = models.iter().map(|m| m.id.clone()).collect();
    assert!(model_ids.contains(&"microsoft/DialoGPT-medium".to_string()));
    assert!(model_ids.contains(&"meta-llama/Llama-2-7b-chat-hf".to_string()));
}

#[tokio::test]
async fn test_router_creation_and_provider_registration() {
    let config = RouterConfig {
        default_provider: Some("test_provider".to_string()),
        allow_remote_routing: true,
        routing_strategy: RoutingStrategy::BestFit,
        routing_timeout_ms: 30000,
        max_routing_attempts: 3,
    };

    let router = AIRouter::new(config);

    // Test that we can get the registry
    let registry = router.registry();
    assert!(registry.list_providers().is_empty());
}

#[tokio::test]
async fn test_squirrel_registry() {
    let registry = SquirrelRegistry::new();

    // Test node registration
    let node = SquirrelNode {
        id: "test-node-1".to_string(),
        name: "Test Node 1".to_string(),
        endpoint: "https://test.example.com".to_string(),
        capabilities: HashMap::new(),
        status: NodeStatus::Online,
        priority: 80,
        region: Some("us-west-2".to_string()),
        tags: vec!["test".to_string()],
    };

    let result = registry.register_node(node.clone()).await;
    assert!(result.is_ok());

    // Test node retrieval
    let retrieved = registry.get_node("test-node-1").await;
    assert!(retrieved.is_some());
    assert_eq!(retrieved.unwrap().name, "Test Node 1");

    // Test node listing
    let nodes = registry.list_nodes().await;
    assert_eq!(nodes.len(), 1);
    assert_eq!(nodes[0].id, "test-node-1");
}

#[tokio::test]
async fn test_routing_request_creation() {
    let request = RoutingRequest {
        request_id: Some("test-request-1".to_string()),
        squirrel_id: None,
        task: AITask {
            task_type: TaskType::TextGeneration,
            required_model_type: None,
            min_context_size: None,
            requires_streaming: false,
            requires_function_calling: false,
            requires_tool_use: false,
            security_requirements: SecurityRequirements::default(),
            complexity_score: None,
            priority: 50,
        },
        routing_hint: None,
        chat_request: ChatRequest {
            model: None,
            messages: vec![ChatMessage {
                role: MessageRole::User,
                content: Some("Hello, world!".to_string()),
                name: None,
                tool_calls: None,
                tool_call_id: None,
            }],
            parameters: Some(ModelParameters {
                temperature: Some(0.7),
                max_tokens: Some(100),
                top_p: None,
                frequency_penalty: None,
                presence_penalty: None,
                stop: None,
                stream: Some(false),
                tool_choice: None,
            }),
            tools: None,
        },
        user_preference: Some(UserPreference {
            preferred_provider: None,
            preferred_model: None,
            cost_preference: None,
            privacy_level: Some(PrivacyLevel::Public),
            performance_preference: None,
        }),
    };

    assert_eq!(request.request_id, Some("test-request-1".to_string()));
    assert_eq!(request.task.task_type, TaskType::TextGeneration);
    assert_eq!(request.chat_request.messages.len(), 1);
    assert_eq!(request.chat_request.messages[0].role, MessageRole::User);
}

#[tokio::test]
async fn test_privacy_level_routing() {
    let private_request = RoutingRequest {
        request_id: Some("privacy-test".to_string()),
        squirrel_id: None,
        task: AITask {
            task_type: TaskType::TextGeneration,
            required_model_type: None,
            min_context_size: None,
            requires_streaming: false,
            requires_function_calling: false,
            requires_tool_use: false,
            security_requirements: SecurityRequirements {
                contains_sensitive_data: true,
                requires_local_processing: true,
                max_data_retention_days: Some(0),
                allowed_regions: vec!["local".to_string()],
                compliance_requirements: vec!["GDPR".to_string()],
            },
            complexity_score: None,
            priority: 80,
        },
        routing_hint: None,
        chat_request: ChatRequest {
            model: None,
            messages: vec![ChatMessage {
                role: MessageRole::User,
                content: Some("This is sensitive data".to_string()),
                name: None,
                tool_calls: None,
                tool_call_id: None,
            }],
            parameters: None,
            tools: None,
        },
        user_preference: Some(UserPreference {
            preferred_provider: None,
            preferred_model: None,
            cost_preference: None,
            privacy_level: Some(PrivacyLevel::Private),
            performance_preference: None,
        }),
    };

    // Test that privacy requirements are properly set
    assert!(
        private_request
            .task
            .security_requirements
            .contains_sensitive_data
    );
    assert!(
        private_request
            .task
            .security_requirements
            .requires_local_processing
    );
    assert_eq!(
        private_request
            .user_preference
            .as_ref()
            .unwrap()
            .privacy_level,
        Some(PrivacyLevel::Private)
    );
}

#[tokio::test]
async fn test_provider_health_checks() {
    let mut registry = ProviderPluginRegistry::new();

    // Create a test provider (this will fail health check due to invalid config)
    let config = ProviderConfig {
        provider_type: "huggingface".to_string(),
        name: "test_hf_health".to_string(),
        enabled: true,
        priority: 70,
        settings: {
            let mut settings = HashMap::new();
            settings.insert("api_key".to_string(), json!("invalid-key"));
            settings
        },
        rate_limits: None,
        retry_config: None,
    };

    let provider_result = registry.create_provider(config).await;
    assert!(provider_result.is_ok());

    // Test health check (will likely fail due to invalid key, but shouldn't panic)
    let health_results = registry.health_check_all().await;
    assert!(health_results.contains_key("test_hf_health"));
}

#[tokio::test]
async fn test_cost_estimation() {
    let mut registry = ProviderPluginRegistry::new();

    let config = ProviderConfig {
        provider_type: "huggingface".to_string(),
        name: "test_cost".to_string(),
        enabled: true,
        priority: 70,
        settings: {
            let mut settings = HashMap::new();
            settings.insert("api_key".to_string(), json!("test-key"));
            settings
        },
        rate_limits: None,
        retry_config: None,
    };

    let provider = registry.create_provider(config).await.unwrap();

    let request = ChatRequest {
        model: None,
        messages: vec![ChatMessage {
            role: MessageRole::User,
            content: Some("Test message".to_string()),
            name: None,
            tool_calls: None,
            tool_call_id: None,
        }],
        parameters: Some(ModelParameters {
            max_tokens: Some(100),
            temperature: Some(0.7),
            top_p: None,
            frequency_penalty: None,
            presence_penalty: None,
            stop: None,
            stream: Some(false),
            tool_choice: None,
        }),
        tools: None,
    };

    let cost_estimate = provider.plugin().estimate_cost(&request).await;
    assert!(cost_estimate.is_ok());

    let estimate = cost_estimate.unwrap();
    assert_eq!(estimate.estimated_cost_usd, 0.0); // HuggingFace free tier
    assert_eq!(estimate.currency, "USD");
}

#[tokio::test]
async fn test_routing_strategies() {
    let strategies = vec![
        RoutingStrategy::FirstMatch,
        RoutingStrategy::HighestPriority,
        RoutingStrategy::LowestLatency,
        RoutingStrategy::LowestCost,
        RoutingStrategy::BestFit,
        RoutingStrategy::RoundRobin,
    ];

    for strategy in strategies {
        let config = RouterConfig {
            default_provider: None,
            allow_remote_routing: true,
            routing_strategy: strategy,
            routing_timeout_ms: 30000,
            max_routing_attempts: 3,
        };

        let router = AIRouter::new(config);
        assert_eq!(router.config.routing_strategy, strategy);
    }
}

#[tokio::test]
async fn test_api_state_creation() {
    let config = RouterConfig::default();
    let router = Arc::new(AIRouter::new(config));
    let squirrel_registry = Arc::new(SquirrelRegistry::new());

    let api_state = ApiState {
        router,
        squirrel_registry,
    };

    // Test that we can access the components
    assert!(api_state.router.registry().list_providers().is_empty());
    assert!(api_state.squirrel_registry.list_nodes().await.is_empty());
}

#[tokio::test]
async fn test_model_capabilities() {
    let mut registry = ProviderPluginRegistry::new();

    let config = ProviderConfig {
        provider_type: "huggingface".to_string(),
        name: "test_capabilities".to_string(),
        enabled: true,
        priority: 70,
        settings: {
            let mut settings = HashMap::new();
            settings.insert("api_key".to_string(), json!("test-key"));
            settings
        },
        rate_limits: None,
        retry_config: None,
    };

    let provider = registry.create_provider(config).await.unwrap();

    // Test getting capabilities for a model
    let capabilities = provider
        .plugin()
        .get_capabilities("microsoft/DialoGPT-medium")
        .await;
    assert!(capabilities.is_ok());

    let caps = capabilities.unwrap();
    assert!(caps.max_context_size > 0);
    assert!(!caps.supports_function_calling); // Most HF models don't support this
}

#[tokio::test]
async fn test_provider_stats() {
    let mut registry = ProviderPluginRegistry::new();

    let config = ProviderConfig {
        provider_type: "huggingface".to_string(),
        name: "test_stats".to_string(),
        enabled: true,
        priority: 70,
        settings: {
            let mut settings = HashMap::new();
            settings.insert("api_key".to_string(), json!("test-key"));
            settings
        },
        rate_limits: None,
        retry_config: None,
    };

    let provider = registry.create_provider(config).await.unwrap();

    let stats = provider.plugin().get_stats().await;
    assert!(stats.is_ok());

    let stats = stats.unwrap();
    assert_eq!(stats.total_requests, 0); // New provider
    assert_eq!(stats.successful_requests, 0);
    assert_eq!(stats.failed_requests, 0);
    assert_eq!(stats.uptime_percentage, 100.0);
}

