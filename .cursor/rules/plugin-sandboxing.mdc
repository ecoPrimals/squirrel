## Examples

<example>
// Create a cross-platform sandbox that selects the appropriate implementation
let resource_monitor = Arc::new(ResourceMonitor::new());
let sandbox = CrossPlatformSandbox::new(resource_monitor)?;

// Create sandbox for a plugin
let plugin_id = Uuid::new_v4();
sandbox.create_sandbox(plugin_id).await?;

// Set permissions and resource limits
let mut context = SecurityContext::default();
context.permission_level = PermissionLevel::Restricted;
context.allowed_capabilities = ["file:read", "plugin:read"]
    .iter().map(|s| s.to_string()).collect();
context.resource_limits = ResourceLimits {
    max_memory_bytes: 100 * 1024 * 1024, // 100 MB
    max_cpu_percent: 10,                 // 10% CPU
    max_threads: 4,
};
sandbox.set_security_context(plugin_id, context).await?;

// Validate operations
sandbox.check_permission(plugin_id, "filesystem:read").await?;   // OK
let result = sandbox.check_permission(plugin_id, "filesystem:write").await;
assert!(result.is_err());  // Restricted level can't write

// Monitor resources
let usage = sandbox.track_resources(plugin_id).await?;
println!("Memory: {} MB, CPU: {}%", usage.memory_mb, usage.cpu_percent);

// Clean up
sandbox.destroy_sandbox(plugin_id).await?;
</example>

