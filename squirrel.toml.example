# Squirrel Configuration File (TOML)
# 
# This file demonstrates all available configuration options.
# Copy to 'squirrel.toml' and customize as needed.
#
# Configuration precedence (highest to lowest):
# 1. Environment variables (SQUIRREL_*)
# 2. CLI arguments
# 3. This configuration file
# 4. Built-in defaults

[server]
# Unix socket path (overrides default discovery)
# Default: Auto-discovered from SQUIRREL_SOCKET env or /tmp/squirrel-{node_id}.sock
#socket = "/tmp/squirrel-custom.sock"

# Bind address (for future HTTP server)
bind = "0.0.0.0"

# Port (for future HTTP server) 
port = 9010

# Run as daemon (detach from terminal)
daemon = false

# Maximum concurrent connections
max_connections = 100

# Request timeout in seconds
request_timeout_secs = 30

[ai]
# Enable AI router
enabled = true

# AI provider socket paths (comma-separated)
# Example: provider_sockets = "/tmp/provider1.sock,/tmp/provider2.sock"
# Default: Discovered from AI_PROVIDER_SOCKETS env var
#provider_sockets = "/tmp/ai-provider-1.sock,/tmp/ai-provider-2.sock"

# Enable retry with fallback providers
enable_retry = true

# Maximum retry attempts
max_retries = 2

[logging]
# Log level: trace, debug, info, warn, error
level = "info"

# Enable JSON logging (for structured logging)
json = false

# Log to file (optional)
# file = "/var/log/squirrel/squirrel.log"

[discovery]
# Announce capabilities to registry on startup
announce_capabilities = true

# Capabilities to announce
capabilities = [
    "ai.text_generation",
    "ai.image_generation",
    "ai.routing",
    "tool.orchestration"
]

# Registry socket path for capability announcement
# Default: Discovered from SQUIRREL_REGISTRY_SOCKET env var
#registry_socket = "/tmp/registry.sock"

