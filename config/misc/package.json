{
  "name": "squirrel-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:fixed-port": "vite --port 1420 --host",
    "free-port": "node scripts/free-port.js",
    "check-server": "node scripts/check-server.js 1420",
    "open-ui": "node scripts/check-browser.js 1420",
    "wsl-ip": "node scripts/wsl-ip.js",
    "launch": "node scripts/ui-launcher.js",
    "start": "npm run launch",
    "start:clean": "npm run free-port --force && npm run launch",
    "start:safe": "npm run free-port --force && npm run check-server && npm run launch",
    "ui:start": "node scripts/start-ui.js",
    "ui:open": "npm run ui:start && npm run open-ui",
    "ui:wsl": "chmod +x scripts/wsl-ip.js && npm run wsl-ip 3000",
    "ui": "chmod +x scripts/ui-launcher.js && npm run launch",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "jest --config=jest.config.js",
    "test:watch": "jest --config=jest.config.js --watch",
    "test:server": "jest src/tests/server.test.ts --config=jest.config.js",
    "migrate-tests": "node scripts/migrate-vitest-to-jest.js"
  },
  "dependencies": {
    "@tauri-apps/api": "^1.5.1",
    "chart.js": "^4.4.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^2.30.0",
    "pako": "^2.1.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0",
    "react-pro-sidebar": "^1.1.0-alpha.1",
    "react-router-dom": "^6.19.0",
    "react-window": "^1.8.11",
    "uuid": "^9.0.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.5.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.43",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.16",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^22.1.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "ts-jest": "^29.3.2",
    "typescript": "^5.0.2",
    "vite": "^4.4.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "useESM": false
        }
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/crates/"
    ]
  }
}
